-- NetChain, Daml Script tests (the 3 on-ledger wins).
-- Written test-first: these define the behaviour NetChain.daml must satisfy.
module Test where

import Daml.Script
import DA.Assert ((===))
import NetChain

-- Shared demo cast: the netting operator (settlement bank) + 3 companies.
data Setup = Setup with
  operator : Party
  a : Party
  b : Party
  c : Party

parties : Script Setup
parties = do
  operator <- allocateParty "operator"
  a <- allocateParty "CompanyA"
  b <- allocateParty "CompanyB"
  c <- allocateParty "CompanyC"
  pure Setup with operator, a, b, c

-- The canonical netting graph → nets: A +15k, B +30k, C -45k (sum 0).
-- Accounts seeded at 100k each; policy caps are parameters so a test can
-- deliberately trip one.
seedCycle :
  Setup -> Text -> Decimal -> Decimal -> Decimal
  -> Script (ContractId NettingCycle, [ContractId Account], [ContractId TreasuryPolicy])
seedCycle Setup{operator, a, b, c} cycleId capA capB capC = do
  accA <- submit operator $ createCmd Account with operator, owner = a, balance = 100000.0
  accB <- submit operator $ createCmd Account with operator, owner = b, balance = 100000.0
  accC <- submit operator $ createCmd Account with operator, owner = c, balance = 100000.0
  polA <- submit a $ createCmd TreasuryPolicy with operator, party = a, maxSettlementPerCycle = capA
  polB <- submit b $ createCmd TreasuryPolicy with operator, party = b, maxSettlementPerCycle = capB
  polC <- submit c $ createCmd TreasuryPolicy with operator, party = c, maxSettlementPerCycle = capC
  let ob obligor obligee amt ref = submit obligor $ createCmd Obligation with operator, obligor, obligee, amount = amt, reference = ref, dueDate = "2026-07-20", settled = False
  o1 <- ob a b 120000.0 "AB"
  o2 <- ob b c 95000.0 "BC"
  o3 <- ob c a 150000.0 "CA"
  o4 <- ob a c 40000.0 "AC"
  o5 <- ob b a 25000.0 "BA"
  o6 <- ob c b 30000.0 "CB"
  cyc <- submit operator $ createCmd NettingCycle with
    operator, participants = [a, b, c], obligationCids = [o1, o2, o3, o4, o5, o6], cycleId, settled = False
  pure (cyc, [accA, accB, accC], [polA, polB, polC])

-- WIN 1, counterparty privacy: C is not a stakeholder on A→B, so the ledger
-- never returns it to C. A (obligor) does see it.
test_counterparty_privacy : Script ()
test_counterparty_privacy = do
  Setup{operator, a, b, c} <- parties
  _ <- submit a $ createCmd Obligation with operator, obligor = a, obligee = b, amount = 120000.0, reference = "INV-1", dueDate = "2026-07-20", settled = False
  cObls <- query @Obligation c
  length cObls === 0
  aObls <- query @Obligation a
  length aObls === 1

-- WIN 3a, atomic settlement moves every balance in one commit.
test_atomic_settlement : Script ()
test_atomic_settlement = do
  s@Setup{operator, a, b, c} <- parties
  (cyc, accs, pols) <- seedCycle s "cyc-1" 200000.0 500000.0 350000.0
  nps <- submit operator $ exerciseCmd cyc ComputeNetPositions
  _ <- submit operator $ exerciseCmd cyc Settle with
    netPositionCids = nps, accountCids = accs, policyCids = pols
  [(_, accA)] <- query @Account a
  accA.balance === 115000.0
  [(_, accB)] <- query @Account b
  accB.balance === 130000.0
  [(_, accC)] <- query @Account c
  accC.balance === 55000.0
  -- C1 fix: every settled obligation is now marked settled on-ledger, so a
  -- later cycle's "open obligations" filter will not re-include it.
  obls <- query @Obligation operator
  all (\(_, o) -> o.settled) obls === True

-- WIN 3b, all-or-nothing: C's cap (10k) is below its net (45k), so Settle
-- aborts and NOT ONE balance moves.
test_settlement_atomic_abort : Script ()
test_settlement_atomic_abort = do
  s@Setup{operator, a, b, c} <- parties
  (cyc, accs, pols) <- seedCycle s "cyc-2" 200000.0 500000.0 10000.0
  nps <- submit operator $ exerciseCmd cyc ComputeNetPositions
  submitMustFail operator $ exerciseCmd cyc Settle with
    netPositionCids = nps, accountCids = accs, policyCids = pols
  [(_, accA)] <- query @Account a
  accA.balance === 100000.0
  [(_, accC)] <- query @Account c
  accC.balance === 100000.0

-- C2 fix, no double settle: Settle is consuming and returns a NEW cycle
-- contract with settled = True. Exercising Settle again on that returned
-- contract must fail on the `not this.settled` guard, before it ever
-- touches netPositionCids/accountCids/policyCids (so balances cannot move
-- twice even if stale NetPositions were somehow still active).
test_no_double_settle : Script ()
test_no_double_settle = do
  s@Setup{operator} <- parties
  (cyc, accs, pols) <- seedCycle s "cyc-double" 200000.0 500000.0 350000.0
  nps <- submit operator $ exerciseCmd cyc ComputeNetPositions
  cyc2 <- submit operator $ exerciseCmd cyc Settle with
    netPositionCids = nps, accountCids = accs, policyCids = pols
  submitMustFail operator $ exerciseCmd cyc2 Settle with
    netPositionCids = [], accountCids = [], policyCids = []

-- WIN 4, the on-ledger policy the agent cannot bypass: 250k > 200k cap fails
-- on-ledger; a within-cap amount succeeds.
test_policy_rejects_over_threshold : Script ()
test_policy_rejects_over_threshold = do
  Setup{operator, a} <- parties
  polA <- submit a $ createCmd TreasuryPolicy with
    operator, party = a, maxSettlementPerCycle = 200000.0
  submitMustFail operator $ exerciseCmd polA CheckSettlement with amount = 250000.0
  submit operator $ exerciseCmd polA CheckSettlement with amount = 150000.0

-- WIN 5 (T23), pre-cycle funding check flags an underfunded net payer BEFORE
-- Settle. Same 460k graph, but C is funded only 10k while its net is -45k, so
-- CheckFunding returns [C]. A (net +15k) and B (net +30k) are not flagged.
test_prefunding_check : Script ()
test_prefunding_check = do
  Setup{operator, a, b, c} <- parties
  accA <- submit operator $ createCmd Account with operator, owner = a, balance = 100000.0
  accB <- submit operator $ createCmd Account with operator, owner = b, balance = 100000.0
  accC <- submit operator $ createCmd Account with operator, owner = c, balance = 10000.0
  let ob obligor obligee amt ref = submit obligor $ createCmd Obligation with operator, obligor, obligee, amount = amt, reference = ref, dueDate = "2026-07-20", settled = False
  o1 <- ob a b 120000.0 "AB"
  o2 <- ob b c 95000.0 "BC"
  o3 <- ob c a 150000.0 "CA"
  o4 <- ob a c 40000.0 "AC"
  o5 <- ob b a 25000.0 "BA"
  o6 <- ob c b 30000.0 "CB"
  cyc <- submit operator $ createCmd NettingCycle with
    operator, participants = [a, b, c], obligationCids = [o1, o2, o3, o4, o5, o6], cycleId = "cyc-fund", settled = False
  nps <- submit operator $ exerciseCmd cyc ComputeNetPositions
  under <- submit operator $ exerciseCmd cyc CheckFunding with
    netPositionCids = nps, accountCids = [accA, accB, accC]
  under === [c]

-- WIN 6 (T24), drop-and-re-net: exclude the underfunded C and settle the
-- survivors A and B over only the obligations that do not involve C
-- (AB 120k, BA 25k). A nets -95k, B nets +95k, so A -> 5k, B -> 195k. C's
-- obligations stay open. Never unwind a settled batch.
test_drop_and_renet : Script ()
test_drop_and_renet = do
  Setup{operator, a, b, c} <- parties
  accA <- submit operator $ createCmd Account with operator, owner = a, balance = 100000.0
  accB <- submit operator $ createCmd Account with operator, owner = b, balance = 100000.0
  polA <- submit a $ createCmd TreasuryPolicy with operator, party = a, maxSettlementPerCycle = 500000.0
  polB <- submit b $ createCmd TreasuryPolicy with operator, party = b, maxSettlementPerCycle = 500000.0
  let ob obligor obligee amt ref = submit obligor $ createCmd Obligation with operator, obligor, obligee, amount = amt, reference = ref, dueDate = "2026-07-20", settled = False
  o1 <- ob a b 120000.0 "AB"
  o2 <- ob b c 95000.0 "BC"
  o3 <- ob c a 150000.0 "CA"
  o4 <- ob a c 40000.0 "AC"
  o5 <- ob b a 25000.0 "BA"
  o6 <- ob c b 30000.0 "CB"
  cyc <- submit operator $ createCmd NettingCycle with
    operator, participants = [a, b, c], obligationCids = [o1, o2, o3, o4, o5, o6], cycleId = "cyc-drop", settled = False
  nps <- submit operator $ exerciseCmd cyc ComputeNetPositionsExcluding with excluded = [c]
  _ <- submit operator $ exerciseCmd cyc Settle with
    netPositionCids = nps, accountCids = [accA, accB], policyCids = [polA, polB]
  [(_, aAcc)] <- query @Account a
  aAcc.balance === 5000.0
  [(_, bAcc)] <- query @Account b
  bAcc.balance === 195000.0

-- WIN 7 (T25), partial settlement / largest solvent subset: TWO net payers
-- (B, C) are underfunded at once, A is the sole solvent net receiver. Graph is
-- just B->A 50k and C->A 60k, so nets are A +110k, B -50k, C -60k (sum 0).
-- B's account holds 20k (< 50k owed) and C's holds 15k (< 60k owed), so
-- CheckFunding flags both. Excluding both leaves A as the only survivor; since
-- every obligation touches B or C, A's re-netted position is 0, so Settle is a
-- no-op on A's balance, but it proves the composition (CheckFunding ->
-- ComputeNetPositionsExcluding -> Settle) excludes every underfunded payer at
-- once and settles the solvent remainder atomically. B and C's obligations
-- are never archived, so they stay open for a later cycle.
test_partial_settlement : Script ()
test_partial_settlement = do
  Setup{operator, a, b, c} <- parties
  accA <- submit operator $ createCmd Account with operator, owner = a, balance = 100000.0
  accB <- submit operator $ createCmd Account with operator, owner = b, balance = 20000.0
  accC <- submit operator $ createCmd Account with operator, owner = c, balance = 15000.0
  polA <- submit a $ createCmd TreasuryPolicy with operator, party = a, maxSettlementPerCycle = 500000.0
  polB <- submit b $ createCmd TreasuryPolicy with operator, party = b, maxSettlementPerCycle = 500000.0
  polC <- submit c $ createCmd TreasuryPolicy with operator, party = c, maxSettlementPerCycle = 500000.0
  let ob obligor obligee amt ref = submit obligor $ createCmd Obligation with operator, obligor, obligee, amount = amt, reference = ref, dueDate = "2026-07-20", settled = False
  o1 <- ob b a 50000.0 "BA"
  o2 <- ob c a 60000.0 "CA"
  cyc <- submit operator $ createCmd NettingCycle with
    operator, participants = [a, b, c], obligationCids = [o1, o2], cycleId = "cyc-partial", settled = False
  nps <- submit operator $ exerciseCmd cyc ComputeNetPositions
  under <- submit operator $ exerciseCmd cyc CheckFunding with
    netPositionCids = nps, accountCids = [accA, accB, accC]
  under === [b, c]
  survivorNps <- submit operator $ exerciseCmd cyc ComputeNetPositionsExcluding with
    excluded = under
  _ <- submit operator $ exerciseCmd cyc Settle with
    netPositionCids = survivorNps, accountCids = [accA], policyCids = [polA]
  [(_, aAcc)] <- query @Account a
  aAcc.balance === 100000.0
  [(_, bObl)] <- query @Obligation b
  bObl.settled === False
  [(_, cObl)] <- query @Obligation c
  cObl.settled === False
