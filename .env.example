# NetChain — Canton Devnet (5N Sandbox) config.
# Copy to `.env`, fill CLIENT_SECRET, then `source .env`. NEVER commit `.env`.
# Full details + curl patterns: docs/CANTON_E2E_GUIDE.md

BASE=https://ledger-api.validator.devnet.sandbox.fivenorth.io
WS_BASE=wss://ledger-api.validator.devnet.sandbox.fivenorth.io
TOKEN_ENDPOINT=https://auth.sandbox.fivenorth.io/application/o/token/

CLIENT_ID=validator-devnet-m2m
CLIENT_SECRET=            # <-- paste from the 5N Sandbox access doc; DO NOT COMMIT
AUDIENCE=validator-devnet-m2m
SCOPE=daml_ledger_api

# Identity resolved from the shared M2M user (public identifiers, not secrets):
USER_ID=6
PRIMARY_PARTY=5nsandbox-devnet-2::1220a14ca128063b8dc9d1ebb0bd22633be9f2168500f4dbc1ecaeb1855b14e5acf8
SYNCHRONIZER=global-domain::1220be58c29e65de40bf273be1dc2b266d43a9a002ea5b18955aeef7aac881bb471a

# NetChain Daml package deployed on Devnet (public hash) — build JSON API templateIds
# as "$NETCHAIN_PKG_ID:NetChain:<Template>" for commands, "#netchain:NetChain:<Template>" for filters.
NETCHAIN_PKG_ID=cdd76816c72bba50c880ea7f8d48c9f78ae5d37e48706aa012cfeac80ee655e7
